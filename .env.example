# ─────────────────────────────────────────────────────────────
# FanForge environment (MERN)
# Copy to server/.env. EVERYTHING here is optional — the app runs
# fully offline with deterministic fallbacks when keys are absent.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# --- MongoDB (M in MERN) ---
# If this URI is unreachable, FanForge auto-starts an in-memory
# mongod (mongodb-memory-server) so the demo never depends on a
# local install. Set USE_MEMORY_DB=true to force it.
MONGODB_URI=mongodb://127.0.0.1:27017/fanforge
USE_MEMORY_DB=false

# --- Gemini (structured passion scoring). Falls back to a
#     deterministic heuristic scorer when absent. ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Snowflake passion warehouse. Scored moments stream into a
#     PASSION_MOMENTS table; /api/warehouse answers with Snowflake SQL.
#     Falls back to Mongo aggregations when absent. ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FANFORGE
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_TABLE=PASSION_MOMENTS

# --- football-data.org (live World Cup feed). Falls back to the
#     seeded dataset in server/src/data. ---
FOOTBALL_DATA_API_KEY=

# --- ElevenLabs hype narration. Lights up automatically when the
#     key exists (set FEATURE_ELEVENLABS=false to force off). ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Solana "Passion Points" badge. Lights up automatically when a
#     mint keypair exists (set FEATURE_SOLANA=false to force off);
#     without it, minting is simulated and clearly labelled. ---
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_MINT_SECRET=

# --- Ingestion loop. 0 disables the background poll; the /api/ingest
#     route still works on demand. ---
INGEST_INTERVAL_MS=0
