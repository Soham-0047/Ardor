# ─────────────────────────────────────────────────────────────
# FanForge environment (MERN)
# Copy to server/.env. EVERYTHING here is optional — the app runs
# fully offline with deterministic fallbacks when keys are absent.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# --- MongoDB (M in MERN) ---
# If this URI is unreachable, FanForge auto-starts an in-memory
# mongod (mongodb-memory-server) so the demo never depends on a
# local install. Set USE_MEMORY_DB=true to force it.
MONGODB_URI=mongodb://127.0.0.1:27017/fanforge
USE_MEMORY_DB=false

# --- Gemini (structured passion scoring). Falls back to a
#     deterministic heuristic scorer when absent. ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Algolia (instant search). Falls back to Mongo text search. ---
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
ALGOLIA_SEARCH_KEY=
ALGOLIA_INDEX=fanforge_moments

# --- football-data.org (live World Cup feed). Falls back to the
#     seeded dataset in server/src/data. ---
FOOTBALL_DATA_API_KEY=

# --- ElevenLabs hype narration (bonus, feature-flagged) ---
FEATURE_ELEVENLABS=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Solana "Passion Points" badge (stretch, feature-flagged) ---
# With the flag off (or no keypair), minting is simulated and the
# rest of the demo is unaffected.
FEATURE_SOLANA=false
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_MINT_SECRET=

# --- Ingestion loop. 0 disables the background poll; the /api/ingest
#     route still works on demand. ---
INGEST_INTERVAL_MS=0
